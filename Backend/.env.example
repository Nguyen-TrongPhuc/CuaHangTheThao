# SportStore Environment Variables
# Copy this file to .env and fill in your values

# Database
MONGODB_URI=mongodb://127.0.0.1:27017/SportStore

# JWT
JWT_SECRET=sportstore_secret_key_change_this

# VNPay Sandbox Credentials (Get from https://sandbox.vnpayment.vn)
# CẤU HÌNH VNPAY
VNPAY_TMNCODE=0NT9SYND
VNPAY_HASHSECRET=UHJ4LWPL4I33HFOYXLXHQTJFCQI6VCPF
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html

# CHÚ Ý: Đổi cổng 3005 thành đúng cổng mà trang Web Frontend của bạn đang chạy
# Ví dụ nếu web đang chạy ở http://localhost:5173 thì đổi 3005 thành 5173
VNPAY_RETURN_URL=http://localhost:3005/payment-result

# For local testing with ngrok (replace abc.ngrok-free.app with your ngrok URL)
# VNPAY_RETURN_URL=https://abc.ngrok-free.app/api/payment/vnpay/callback

# Cloudinary (optional)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email (for order notifications)
MAIL_USER=your_email@gmail.com
MAIL_PASSWORD=your_app_password

# Shop location (for shipping calculation)
SHOP_LAT=10.0299337
SHOP_LNG=105.7706153
SHOP_ADDRESS="Your shop address, Can Tho"
SHOP_NAME="SportStore"

